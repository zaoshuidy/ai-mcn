{
  "$defs": {
    "BrandInfo": {
      "description": "品牌与投放基础信息（平台与内容形式拆分）。",
      "properties": {
        "brand_name": {
          "description": "品牌名",
          "title": "Brand Name",
          "type": "string"
        },
        "product_name": {
          "description": "产品名",
          "title": "Product Name",
          "type": "string"
        },
        "product_category": {
          "default": "",
          "description": "产品类目",
          "title": "Product Category",
          "type": "string"
        },
        "platform": {
          "default": "",
          "description": "投放平台，如 小红书",
          "title": "Platform",
          "type": "string"
        },
        "content_format": {
          "default": "",
          "description": "内容形式，如 短视频",
          "title": "Content Format",
          "type": "string"
        },
        "campaign_goal": {
          "default": "",
          "description": "投放/内容目标",
          "title": "Campaign Goal",
          "type": "string"
        }
      },
      "required": [
        "brand_name",
        "product_name"
      ],
      "title": "BrandInfo",
      "type": "object"
    },
    "ClaimType": {
      "description": "卖点声明的证据等级。\n\n- confirmed：有包装、检测报告等品牌方提供依据的事实声明；\n- brand_claim：品牌方主张但暂未提供依据，引用时必须保留\"品牌方宣称\"语境；\n- subjective_experience：主观体验类描述，不得表述为客观功效；\n- unverified：未经验证，不得扩展、不得表述为功效。",
      "enum": [
        "confirmed",
        "brand_claim",
        "subjective_experience",
        "unverified"
      ],
      "title": "ClaimType",
      "type": "string"
    },
    "ComplianceBoundary": {
      "description": "合规边界（兼容旧结构）。",
      "properties": {
        "prohibited_claims": {
          "description": "禁止承诺的功效，如 减肥/降糖",
          "items": {
            "type": "string"
          },
          "title": "Prohibited Claims",
          "type": "array"
        },
        "rules": {
          "description": "其他合规要求",
          "items": {
            "type": "string"
          },
          "title": "Rules",
          "type": "array"
        },
        "audience_interest_not_product_claim": {
          "description": "仅可作为人群兴趣标签、不得转为产品功效的词，如 控糖",
          "items": {
            "type": "string"
          },
          "title": "Audience Interest Not Product Claim",
          "type": "array"
        }
      },
      "title": "ComplianceBoundary",
      "type": "object"
    },
    "ComplianceRule": {
      "description": "单条合规规则。",
      "properties": {
        "category": {
          "description": "规则类别，如 减肥功效承诺",
          "title": "Category",
          "type": "string"
        },
        "prohibited_expressions": {
          "description": "禁止表述",
          "items": {
            "type": "string"
          },
          "title": "Prohibited Expressions",
          "type": "array"
        },
        "restricted_expressions": {
          "description": "限制表述",
          "items": {
            "type": "string"
          },
          "title": "Restricted Expressions",
          "type": "array"
        },
        "reason": {
          "default": "",
          "description": "合规依据",
          "title": "Reason",
          "type": "string"
        },
        "replacement_guidance": {
          "default": "",
          "description": "替代表述建议",
          "title": "Replacement Guidance",
          "type": "string"
        },
        "severity": {
          "default": "high",
          "description": "high / medium / low",
          "title": "Severity",
          "type": "string"
        }
      },
      "required": [
        "category"
      ],
      "title": "ComplianceRule",
      "type": "object"
    },
    "CreatorSearchProfile": {
      "description": "达人搜索画像（Stage 2 输入）。",
      "properties": {
        "content_categories": {
          "description": "内容赛道",
          "items": {
            "type": "string"
          },
          "title": "Content Categories",
          "type": "array"
        },
        "search_keywords": {
          "description": "建议搜索关键词",
          "items": {
            "type": "string"
          },
          "title": "Search Keywords",
          "type": "array"
        },
        "audience_match": {
          "description": "达人粉丝画像要求",
          "items": {
            "type": "string"
          },
          "title": "Audience Match",
          "type": "array"
        },
        "excluded_creator_types": {
          "description": "排除的达人类型",
          "items": {
            "type": "string"
          },
          "title": "Excluded Creator Types",
          "type": "array"
        },
        "style_requirements": {
          "description": "风格要求",
          "items": {
            "type": "string"
          },
          "title": "Style Requirements",
          "type": "array"
        }
      },
      "title": "CreatorSearchProfile",
      "type": "object"
    },
    "MissingInfoItem": {
      "description": "缺失信息项（兼容旧结构）。",
      "properties": {
        "field": {
          "description": "缺失字段",
          "title": "Field",
          "type": "string"
        },
        "question": {
          "description": "需向品牌方确认的问题",
          "title": "Question",
          "type": "string"
        },
        "impact": {
          "description": "对后续阶段的影响",
          "title": "Impact",
          "type": "string"
        },
        "severity": {
          "default": "medium",
          "description": "high / medium / low",
          "title": "Severity",
          "type": "string"
        }
      },
      "required": [
        "field",
        "question",
        "impact"
      ],
      "title": "MissingInfoItem",
      "type": "object"
    },
    "MissingInformation": {
      "description": "缺失信息项（标准结构）。",
      "properties": {
        "field": {
          "description": "缺失字段",
          "title": "Field",
          "type": "string"
        },
        "importance": {
          "default": "medium",
          "description": "high / medium / low",
          "title": "Importance",
          "type": "string"
        },
        "reason": {
          "default": "",
          "description": "为何需要该信息",
          "title": "Reason",
          "type": "string"
        },
        "recommended_action": {
          "default": "",
          "description": "建议补充动作",
          "title": "Recommended Action",
          "type": "string"
        },
        "blocks_next_stage": {
          "default": false,
          "description": "是否阻塞 Stage 2 最终达人定案",
          "title": "Blocks Next Stage",
          "type": "boolean"
        },
        "warn_if_missing": {
          "default": false,
          "description": "缺失时是否生成 warning（计入评分）",
          "title": "Warn If Missing",
          "type": "boolean"
        }
      },
      "required": [
        "field"
      ],
      "title": "MissingInformation",
      "type": "object"
    },
    "ProductVariant": {
      "description": "产品口味/规格变体。",
      "properties": {
        "name": {
          "description": "口味或规格名",
          "title": "Name",
          "type": "string"
        },
        "confirmed": {
          "default": false,
          "description": "是否来自品牌方确认信息",
          "title": "Confirmed",
          "type": "boolean"
        },
        "source": {
          "default": "",
          "description": "信息来源，如 brand_brief",
          "title": "Source",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "title": "ProductVariant",
      "type": "object"
    },
    "SellingPoint": {
      "description": "单个卖点及其证据状态。",
      "properties": {
        "claim": {
          "description": "卖点原文，如 0蔗糖、高蛋白",
          "title": "Claim",
          "type": "string"
        },
        "claim_type": {
          "$ref": "#/$defs/ClaimType",
          "description": "证据等级"
        },
        "evidence": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "依据来源（包装/检测报告等）",
          "title": "Evidence"
        },
        "note": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "使用限制说明",
          "title": "Note"
        },
        "forbidden_interpretations": {
          "description": "禁止的解释方向，如 0蔗糖→无糖",
          "items": {
            "type": "string"
          },
          "title": "Forbidden Interpretations",
          "type": "array"
        }
      },
      "required": [
        "claim",
        "claim_type"
      ],
      "title": "SellingPoint",
      "type": "object"
    },
    "TargetAudience": {
      "description": "目标人群。",
      "properties": {
        "age_range": {
          "description": "年龄段原文，如 22-35岁",
          "title": "Age Range",
          "type": "string"
        },
        "age_min": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "年龄下限（须与原文一致）",
          "title": "Age Min"
        },
        "age_max": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "年龄上限（须与原文一致）",
          "title": "Age Max"
        },
        "gender": {
          "description": "性别取向描述",
          "title": "Gender",
          "type": "string"
        },
        "city_scope": {
          "default": "城市",
          "description": "城市范围",
          "title": "City Scope",
          "type": "string"
        },
        "interests": {
          "description": "兴趣标签，如 健身/控糖",
          "items": {
            "type": "string"
          },
          "title": "Interests",
          "type": "array"
        },
        "lifestyle": {
          "description": "生活方式标签",
          "items": {
            "type": "string"
          },
          "title": "Lifestyle",
          "type": "array"
        }
      },
      "required": [
        "age_range",
        "gender"
      ],
      "title": "TargetAudience",
      "type": "object"
    },
    "UsageScenario": {
      "description": "使用场景（结构化、可排序）。",
      "properties": {
        "name": {
          "description": "场景名，如 早餐",
          "title": "Name",
          "type": "string"
        },
        "priority": {
          "description": "优先级，越小越优先",
          "title": "Priority",
          "type": "integer"
        },
        "natural_integration_reason": {
          "default": "",
          "description": "自然植入理由",
          "title": "Natural Integration Reason",
          "type": "string"
        },
        "shooting_feasibility": {
          "default": "",
          "description": "拍摄可行性说明",
          "title": "Shooting Feasibility",
          "type": "string"
        }
      },
      "required": [
        "name",
        "priority"
      ],
      "title": "UsageScenario",
      "type": "object"
    }
  },
  "description": "结构化品牌 Brief 顶层模型（标准结构 + 兼容字段）。",
  "properties": {
    "brief_id": {
      "description": "Brief 标识",
      "title": "Brief Id",
      "type": "string"
    },
    "version": {
      "default": "2.0",
      "description": "数据契约版本",
      "title": "Version",
      "type": "string"
    },
    "brand": {
      "anyOf": [
        {
          "$ref": "#/$defs/BrandInfo"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "品牌与投放基础信息"
    },
    "product_variants": {
      "description": "产品口味/规格变体",
      "items": {
        "$ref": "#/$defs/ProductVariant"
      },
      "title": "Product Variants",
      "type": "array"
    },
    "selling_points": {
      "description": "卖点清单",
      "items": {
        "$ref": "#/$defs/SellingPoint"
      },
      "title": "Selling Points",
      "type": "array"
    },
    "target_audience": {
      "$ref": "#/$defs/TargetAudience"
    },
    "usage_scenarios": {
      "description": "结构化使用场景",
      "items": {
        "$ref": "#/$defs/UsageScenario"
      },
      "title": "Usage Scenarios",
      "type": "array"
    },
    "compliance_rules": {
      "description": "合规规则清单",
      "items": {
        "$ref": "#/$defs/ComplianceRule"
      },
      "title": "Compliance Rules",
      "type": "array"
    },
    "creator_search_profile": {
      "$ref": "#/$defs/CreatorSearchProfile",
      "description": "达人搜索画像"
    },
    "missing_information": {
      "description": "缺失信息（标准结构）",
      "items": {
        "$ref": "#/$defs/MissingInformation"
      },
      "title": "Missing Information",
      "type": "array"
    },
    "source_text": {
      "default": "",
      "description": "原始 Brief 全文",
      "title": "Source Text",
      "type": "string"
    },
    "source_type": {
      "default": "brand_brief_markdown",
      "description": "来源类型",
      "title": "Source Type",
      "type": "string"
    },
    "source_file": {
      "default": "",
      "description": "原始 Brief 文件相对路径",
      "title": "Source File",
      "type": "string"
    },
    "created_at": {
      "description": "结构化时间",
      "title": "Created At",
      "type": "string"
    },
    "validation_status": {
      "default": "pending",
      "description": "ready / ready_with_warnings / blocked / invalid / pending",
      "title": "Validation Status",
      "type": "string"
    },
    "human_verified": {
      "default": false,
      "description": "是否经人工确认",
      "title": "Human Verified",
      "type": "boolean"
    },
    "brand_name": {
      "default": "",
      "description": "[兼容] 品牌名",
      "title": "Brand Name",
      "type": "string"
    },
    "product_name": {
      "default": "",
      "description": "[兼容] 产品名",
      "title": "Product Name",
      "type": "string"
    },
    "product_category": {
      "default": "",
      "description": "[兼容] 产品类目",
      "title": "Product Category",
      "type": "string"
    },
    "flavors": {
      "description": "[兼容] 口味",
      "items": {
        "type": "string"
      },
      "title": "Flavors",
      "type": "array"
    },
    "scenarios": {
      "description": "[兼容] 使用场景",
      "items": {
        "type": "string"
      },
      "title": "Scenarios",
      "type": "array"
    },
    "platform": {
      "default": "",
      "description": "[兼容] 投放平台原文",
      "title": "Platform",
      "type": "string"
    },
    "content_goal": {
      "default": "",
      "description": "[兼容] 内容目标",
      "title": "Content Goal",
      "type": "string"
    },
    "content_requirements": {
      "description": "[兼容] 内容要求",
      "items": {
        "type": "string"
      },
      "title": "Content Requirements",
      "type": "array"
    },
    "compliance": {
      "$ref": "#/$defs/ComplianceBoundary",
      "description": "[兼容] 合规边界"
    },
    "missing_info": {
      "description": "[兼容] 缺失信息",
      "items": {
        "$ref": "#/$defs/MissingInfoItem"
      },
      "title": "Missing Info",
      "type": "array"
    },
    "structured_by": {
      "default": "rule_based_parser",
      "description": "结构化方式",
      "title": "Structured By",
      "type": "string"
    }
  },
  "required": [
    "brief_id",
    "target_audience"
  ],
  "title": "BrandBrief",
  "type": "object"
}